# Copy this file to .env and fill in your values.
# Never commit your actual .env file.

# Your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...

# Absolute path to the root TA folder that contains the lab-<N> subdirectory
# Windows example:  C:\Users\yourname\Desktop\University\TA
# macOS/Linux:      /home/yourname/university/TA
BASE_LAB_DIR=C:\Users\yourname\Desktop\University\TA
